rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Strictly Default-Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getUserRole(userId) {
      return getUserData(userId).role;
    }

    function isAdmin() {
      return isSignedIn() && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'superAdmin');
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'superAdmin';
    }

    // String ID Validation helper
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validate incoming data helper for User creation/editing
    function isValidUser(data) {
      return data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200;
    }

    // ==========================================
    // 1. Users Collection Rules
    // ==========================================
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      // Allow user creation on signup and profile editing
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data);
      
      // Prevent normal users from upgrading their own roles
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (isOwner(userId) && isValidUser(request.resource.data) && 
         request.resource.data.role == resource.data.role)
      );
      
      allow delete: if isSuperAdmin();
    }

    // ==========================================
    // 2. Products Collection Rules
    // ==========================================
    match /products/{productId} {
      // Anyone can view products (published status could be filtered client-side, but let's allow read)
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 3. Collections Collection Rules
    // ==========================================
    match /collections/{collectionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 4. Site Settings CMS Rules
    // ==========================================
    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // 5. Orders Collection Rules
    // ==========================================
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.customerId == request.auth.uid
      );
      
      // Both customers and guests/admins can create orders. 
      // If customer is signed in, enforce customerId check.
      allow create: if true; 
      
      // Admin can update status, paymentStatus, etc.
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ==========================================
    // 6. Payment Verification Rules
    // ==========================================
    match /paymentVerification/{verificationId} {
      // Admins and owners can read
      allow read: if isAdmin();
      // Allow customers to submit payment verification credentials
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ==========================================
    // 7. Notifications Collection Rules
    // ==========================================
    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if true; // Any component can create a notification (e.g. checkouts, signups)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ==========================================
    // 8. Journal Posts Collection Rules
    // ==========================================
    match /journalPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
