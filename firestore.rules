rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      );
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ) &&
        (
          userDoc().data.role == "admin" ||
          userDoc().data.role == "superAdmin"
        );
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ) &&
        userDoc().data.role == "superAdmin";
    }

    function isOwner(uid) {
      return isSignedIn() &&
             request.auth.uid == uid;
    }

    function getOrder(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId));
    }

    // ------------------------
    // USERS
    // ------------------------

    match /users/{userId} {

      allow read:
        if isOwner(userId) || isAdmin();

      allow create:
        if isOwner(userId);

      allow update:
        if isSuperAdmin() ||
        (
          isOwner(userId)
          &&
          request.resource.data.role
          ==
          resource.data.role
        );

      allow delete:
        if isSuperAdmin();
    }

    // ------------------------
    // PRODUCTS
    // ------------------------

    match /products/{productId} {

      allow read: if true;

      allow create, update, delete:
        if isAdmin();
    }

    // ------------------------
    // COLLECTIONS
    // ------------------------

    match /collections/{collectionId} {

      allow read: if true;

      allow create, update, delete:
        if isAdmin();
    }

    // ------------------------
    // SITE SETTINGS
    // ------------------------

    match /siteSettings/{docId} {

      allow read: if true;

      allow create, update, delete:
        if isAdmin();
    }

    // ------------------------
    // ORDERS
    // ------------------------

    match /orders/{orderId} {

      allow read:
        if isAdmin()
        ||
        (
          isSignedIn()
          &&
          resource.data.customerId ==
          request.auth.uid
        )
        ||
        (
          resource.data.customerId == "anonymous"
        );

      allow create:
        if (
          isSignedIn()
          &&
          request.resource.data.customerId ==
          request.auth.uid
        )
        ||
        (
          request.resource.data.customerId == "anonymous"
        );

      allow update:
        if isAdmin();

      allow delete:
        if isAdmin();
    }

    // ------------------------
    // PAYMENT VERIFICATION
    // ------------------------

    match /paymentVerification/{verificationId} {

      allow read:
        if isAdmin()
        ||
        (
          exists(/databases/$(database)/documents/orders/$(resource.data.orderId))
          &&
          (
            (
              isSignedIn()
              &&
              getOrder(resource.data.orderId).data.customerId == request.auth.uid
            )
            ||
            (
              getOrder(resource.data.orderId).data.customerId == "anonymous"
            )
          )
        );

      allow create:
        if request.resource.data.orderId is string
        &&
        exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
        &&
        (
          (
            isSignedIn()
            &&
            getOrder(request.resource.data.orderId).data.customerId == request.auth.uid
          )
          ||
          (
            getOrder(request.resource.data.orderId).data.customerId == "anonymous"
          )
        );

      allow update, delete:
        if isAdmin();
    }

    // ------------------------
    // NOTIFICATIONS
    // ------------------------

    match /notifications/{notificationId} {

      allow read:
        if isAdmin();

      allow create, update, delete:
        if isAdmin();
    }

    // ------------------------
    // JOURNAL POSTS
    // ------------------------

    match /journalPosts/{postId} {

      allow read:
        if true;

      allow create, update, delete:
        if isAdmin();
    }

    // ------------------------
    // REVIEWS
    // ------------------------

    match /reviews/{reviewId} {

      allow read:
        if true;

      allow create:
        if isSignedIn();

      allow update, delete:
        if isAdmin();
    }

    // ------------------------
    // COMMUNITY SNAPS
    // ------------------------

    match /communitySnaps/{snapId} {

      allow read:
        if true;

      allow create:
        if isSignedIn();

      allow update, delete:
        if isAdmin();
    }

    // ------------------------
    // COUPONS
    // ------------------------

    match /coupons/{couponId} {

      allow read:
        if true;

      allow create, update, delete:
        if isAdmin();
    }

    // ------------------------
    // MESSAGES
    // ------------------------

    match /messages/{messageId} {

      allow create:
        if request.resource.data.name is string
        &&
        request.resource.data.email is string
        &&
        request.resource.data.message is string;

      allow read, delete:
        if isAdmin();

      allow update:
        if false;
    }

    // ------------------------
    // MEDIA
    // ------------------------

    match /media/{mediaId} {

      allow read:
        if true;

      allow create, update, delete:
        if isAdmin();
    }

    // ------------------------
    // DEFAULT DENY
    // ------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
